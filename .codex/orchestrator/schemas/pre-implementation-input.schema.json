{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rapida.ai/schemas/orchestrator/pre-implementation-input.schema.json",
  "title": "Pre Implementation Hook Input",
  "type": "object",
  "required": ["task", "task_plan", "meta"],
  "properties": {
    "task": {
      "type": "object",
      "required": ["id", "type", "skill"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "skill": { "type": "string" },
        "provider": { "type": "string" }
      }
    },
    "task_plan": {
      "type": "object",
      "required": ["allowed_paths", "out_of_scope_paths", "required_tests", "required_commands"],
      "properties": {
        "allowed_paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "out_of_scope_paths": { "type": "array", "items": { "type": "string" } },
        "required_tests": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "required_commands": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "meta": { "type": "object" }
  },
  "additionalProperties": true
}
