SERVICE_NAME="workflow-api"
HOST="0.0.0.0"
PORT=9007
LOG_LEVEL="debug"
SECRET="rpd_pks"
ENV="development"

# storage
ASSET_STORE__STORAGE_TYPE="local"
ASSET_STORE__STORAGE_PATH_PREFIX="/app/rapida-data/assets/workflow"
ASSET_STORE__PUBLIC_URL_PREFIX=http://localhost:8080/rapida-data/assets/workflow


# postgres
POSTGRES__HOST="postgres"
POSTGRES__DB_NAME="assistant_db"
POSTGRES__AUTH__USER="rapida_user"
POSTGRES__AUTH__PASSWORD="rapida_db_password"
POSTGRES__PORT=5432
POSTGRES__MAX_OPEN_CONNECTION=50
POSTGRES__MAX_IDEAL_CONNECTION=25
POSTGRES__SSL_MODE="disable"
POSTGRES__SLC_CACHE__HOST="redis"
POSTGRES__SLC_CACHE__PORT=6379
POSTGRES__SLC_CACHE__AUTH__PASSWORD=""
POSTGRES__SLC_CACHE__AUTH__USER=""
POSTGRES__SLC_CACHE__MAX_CONNECTION=10
POSTGRES__SLC_CACHE__DB=1

# redis
REDIS__HOST="redis"
REDIS__PORT=6379
REDIS__AUTH__PASSWORD=""
REDIS__AUTH__USER=""
REDIS__MAX_CONNECTION=10
REDIS__MAX_DB=0


# internal apis
INTEGRATION_HOST=integration-api:9004
ENDPOINT_HOST=endpoint-api:9005
ASSISTANT_HOST=assistant-api:9007
WEB_HOST=web-api:9001
# ngork tunnel for local development, needed for callback URLs in external services like Twilio, Google Dialogflow, etc.
PUBLIC_ASSISTANT_HOST=integral-presently-cub.ngrok-free.app


DOCUMENT_HOST=http://document-api:9010
UI_HOST=https://localhost:3000




# AudioSocket server for Asterisk integration
# Dialplan: same = n,AudioSocket(${CONTEXT_ID},host:port)
AUDIOSOCKET__HOST=0.0.0.0
AUDIOSOCKET__PORT=4573

# SIP Server Configuration for Inbound Calls
# Connect using: sip:{assistantID}:{apiKey}@<YOUR_SERVER_IP>:5090
# SERVER = bind address (0.0.0.0 to listen on all interfaces)
# EXTERNAL_IP = public/reachable IP advertised in SDP and SIP Contact headers
SIP__SERVER=0.0.0.0
SIP__EXTERNAL_IP=0.0.0.0
SIP__PORT=5060
SIP__TRANSPORT=udp
SIP__RTP_PORT_RANGE_START=10000
SIP__RTP_PORT_RANGE_END=10199

# WebRTC ICE configuration (required on EC2 / any cloud server)
# EC2 exposes a public IP via AWS NAT but Pion only sees the private 10.x.x.x IP.
# Set EXTERNAL_IP to the EC2 instance's Elastic/public IP so Pion advertises
# the correct address in ICE candidates. Leave empty for local development.
# Also open UDP 20000-20100 inbound in the EC2 security group.
WEBRTC__EXTERNAL_IP=
WEBRTC__UDP_PORT_RANGE_START=20000
WEBRTC__UDP_PORT_RANGE_END=20100

# Global telemetry — applies to every assistant session.
# Events → rapida-events-YYYYMMDD, Metrics → rapida-metrics-YYYYMMDD
# Uses the OpenSearch connector configured above (OPENSEARCH__*).
# To use a different provider, set TYPE to: otlp_http, datadog, xray, google_trace, azure_monitor, logging
# TELEMETRY__TYPE=opensearch
# TELEMETRY__SCHEMA="http"
# TELEMETRY__HOST="opensearch"
# TELEMETRY__PORT=9200
# TELEMETRY__MAX_RETRIES=3
# TELEMETRY__MAX_CONNECTION=10
