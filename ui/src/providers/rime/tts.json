{
  "preservePrefix": "speaker.",
  "parameters": [
    {
      "key": "speak.model",
      "label": "Model",
      "type": "dropdown",
      "required": true,
      "data": "models.json",
      "valueField": "model_id",
      "errorMessage": "Please select a valid model for text to speech."
    },
    {
      "key": "speak.language",
      "label": "Language",
      "type": "dropdown",
      "required": true,
      "data": "languages.json",
      "valueField": "language_id",
      "errorMessage": "Please select a valid language for text to speech."
    },
    {
      "key": "speak.voice.id",
      "label": "Voice",
      "type": "dropdown",
      "required": true,
      "data": "text-to-speech-voices.json",
      "valueField": "voice_id",
      "searchable": true,
      "strict": false,
      "customValue": true,
      "errorMessage": "Please select a valid voice ID for text to speech."
    },
    {
      "key": "speak.speed_alpha",
      "label": "Speed Alpha",
      "type": "number",
      "required": false,
      "min": 0.1,
      "max": 3,
      "step": 0.1,
      "placeholder": "1.0 (default)"
    }
  ]
}
