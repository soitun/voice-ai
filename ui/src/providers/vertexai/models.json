          "required": true,
          "default": "2048",
          "min": 1,
          "errorMessage": "Please check and provide a correct value for max_completion_tokens"
        },
        {
          "key": "model.stop_sequences",
          "label": "Stop Sequences",
          "type": "input",
          "advanced": true,
          "required": false,
          "default": ""
        },
        {
          "key": "model.presence_penalty",
          "label": "Presence Penalty",
          "type": "slider",
          "advanced": true,
          "required": false,
          "min": -2,
          "max": 2,
          "step": 0.1,
          "errorMessage": "Please check and provide a correct value for presence_penalty a valid value between -2 to 2."
        },
        {
          "key": "model.frequency_penalty",
          "label": "Frequency Penalty",
          "type": "slider",
          "advanced": true,
          "required": false,
          "min": -2,
          "max": 2,
