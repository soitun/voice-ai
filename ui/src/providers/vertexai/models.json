          "label": "Top K",
          "type": "number",
          "advanced": true,
          "required": false
        },
        {
          "key": "model.candidate_count",
          "label": "Candidate Count",
          "type": "number",
          "advanced": true,
          "required": false,
          "default": "1"
        },
        {
          "key": "model.max_output_tokens",
          "label": "Max Output Tokens",
          "type": "number",
